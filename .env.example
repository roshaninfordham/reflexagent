# ===== Reasoning Engine (NVIDIA NIM, OpenAI-compatible) =====
REASONING_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-...
# Optional: separate key for the vision model. Leave blank to reuse NVIDIA_API_KEY.
NVIDIA_VISION_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEXT_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Optional alternate provider (set REASONING_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ===== NimbleWay (Web Search Agents) =====
NIMBLE_API_KEY=your-nimble-key-here

# ===== ClickHouse Cloud =====
CLICKHOUSE_HOST=your-instance.region.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DATABASE=reflex
CLICKHOUSE_KEY_ID=your-key-id
CLICKHOUSE_KEY_SECRET=your-key-secret

# ===== Senso (Publishing) =====
SENSO_API_KEY=tgr_...
SENSO_PUBLISH_TARGET=reflex.cited.md

# ===== Datadog LLM Observability (auto-instrumented via lapdog) =====
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=reflex
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_API_KEY=your-datadog-key
DD_SITE=datadoghq.com

# ===== x402 / Coinbase CDP =====
X402_SECRET=local-dev-secret-change-in-prod
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_NETWORK=base-sepolia
X402_PAY_TO_ADDRESS=
X402_PRICE_USD=0.50

# ===== Reflex API =====
REFLEX_BEARER_TOKEN=local-dev-token-change-in-prod
REFLEX_API_BASE=http://localhost:8000
REFLEX_WEB_BASE=http://localhost:3000

# ===== Monitor =====
MONITOR_POLL_INTERVAL_SECONDS=30
MONITOR_ENABLED=1
